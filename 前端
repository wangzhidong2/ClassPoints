                <option value="individual">个人排行榜</option>
                <option value="group">小组排行榜</option>
            </select>
            <ul class="ranking-list" id="rankingList">
                <!-- 排行榜内容将通过JS动态生成 -->
            </ul>
        </div>
    </div>
    
    <!-- 全班加分模态框 -->
    <div class="modal" id="addScoreModal">
        <div class="modal-content">
