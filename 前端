                        if (row['姓名']) {
                            classes[currentClass].students.push({
                                name: row['姓名'],
                                score: row['积分'] || 0,
                                group: row['小组'] || '未分组',
                                history: [],
                                isLeader: false
                            });
                        }
                    });
                    
                    // 更新组长状态
                    updateGroupLeaders();
                    
                    saveData();
                    
                    if (viewMode === 'individual') {
                        renderStudents();
                    } else {
                        renderGroups();
                    }
                    
                    showNotification(`成功导入 ${classes[currentClass].students.length} 名学生数据`);
                } catch (error) {
                    showNotification('导入失败，请检查文件格式', true);
                    console.error(error);
                }
            };
            reader.readAsArrayBuffer(file);
        }
        
        // 导出积分
        function exportScores() {
            const students = classes[currentClass].students;
            if (!students || students.length === 0) {
                showNotification("没有学生数据可导出", true);
                return;
            }
            
            const wsData = [
                ['姓名', '积分', '小组']
            ];
            
            students.forEach(student => {
                wsData.push([student.name, student.score, student.group]);
            });
            
            const ws = XLSX.utils.aoa_to_sheet(wsData);
            const wb = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(wb, ws, '积分表');
            
            XLSX.writeFile(wb, `${currentClass}积分表.xlsx`);
            showNotification('积分已导出为Excel文件');
        }
        
        // 批量添加学生
        function batchAddStudents() {
            const classSelect = document.getElementById('managerClassSelect');
            const groupSelect = document.getElementById('managerGroupSelect');
            const input = document.getElementById('batchStudentsInput');
            
            const className = classSelect.value;
            const groupName = groupSelect.value;
            const names = input.value.trim().split('\n');
            
            if (names.length === 0 || (names.length === 1 && names[0] === '')) {
                showNotification('请输入学生姓名', true);
                return;
            }
            
            if (!classes[className]) {
                showNotification('请选择有效的班级', true);
                return;
            }
            
            if (!classes[className].students) {
                classes[className].students = [];
            }
            
            let count = 0;
            names.forEach(name => {
                const trimmedName = name.trim();
                if (trimmedName) {
                    // 检查是否已有组长，如果没有则第一个学生设为组长
                    const groupStudents = classes[className].students.filter(s => s.group === groupName);
                    const isLeader = groupStudents.length === 0;
                    
                    classes[className].students.unshift({
                        name: trimmedName,
                        score: 0,
                        group: groupName,
                        history: [],
                        isLeader: isLeader
                    });
                    count++;
                }
            });
            
            if (count > 0) {
                saveData();
                
                if (className === currentClass) {
                    if (viewMode === 'individual') {
                        renderStudents();
                    } else {
                        renderGroups();
                    }
                }
                
                studentManagerModal.style.display = 'none';
                input.value = '';
                showNotification(`成功添加 ${count} 名学生到 ${groupName}`);
            } else {
                showNotification('未添加任何学生', true);
            }
        }
        
        // 修改步值
        function changeStepValue() {
            const stepInput = document.getElementById('stepValueInput');
            const newStep = parseInt(stepInput.value) || 1;
            
            if (newStep <= 0) {
                showNotification('步值必须大于0', true);
                return;
            }
            
            stepValue = newStep;
            saveData();
            updateStepValue();
            changeStepModal.style.display = 'none';
            showNotification(`加减分步值已修改为: ${stepValue}`);
        }
        
        // 创建新班级
        function createNewClass() {
            const classNameInput = document.getElementById('classNameInput');
            const groupCountInput = document.getElementById('groupCountInput');
            
            const className = classNameInput.value.trim();
            const groupCount = parseInt(groupCountInput.value) || 4;
            
            if (className) {
                if (classes[className]) {
                    showNotification('班级名称已存在', true);
                    return;
                }
                
                // 生成小组名称
                const groups = [];
                const groupScores = {};
                for (let i = 1; i <= groupCount; i++) {
                    const groupName = `第${i}组`;
                    groups.push(groupName);
                    groupScores[groupName] = 0;
                }
                
                classes[className] = {
                    students: [],
                    groups: groups,
                    groupScores: groupScores
                };
                
                currentClass = className;
                saveData();
                updateClassTitle();
                updateViewMode();
                classManagerModal.style.display = 'none';
                classNameInput.value = '';
                
                showNotification(`已创建新班级: ${className}`);
            } else {
                showNotification('请输入班级名称', true);
            }
        }
        
        // 重命名班级
        function renameClass() {
            const newName = prompt(`请输入新的班级名称：`, currentClass);
            if (newName && newName.trim() && newName !== currentClass) {
                if (classes[newName]) {
                    showNotification('班级名称已存在', true);
