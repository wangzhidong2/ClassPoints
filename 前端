<body>
    <!-- 密码保护模态框 -->
    <div class="modal password-modal" id="passwordModal">
        <div class="password-container">
            <div class="password-logo">
                <i class="fas fa-lock"></i>
            </div>
            <h2 class="password-title">课堂积分管理系统</h2>
            <div id="passwordForm">
                <div class="password-input-group">
                    <label for="passwordInput">请输入密码：</label>
                    <input type="password" id="passwordInput" placeholder="输入访问密码">
                </div>
                <button class="password-btn" id="loginBtn">登录</button>
                <div class="password-error" id="passwordError"></div>
            </div>
            <div id="changePasswordForm" style="display: none;">
                <div class="password-input-group">
                    <label for="oldPassword">原密码：</label>
                    <input type="password" id="oldPassword" placeholder="输入原密码">
                </div>
                <div class="password-input-group">
                    <label for="newPassword">新密码：</label>
                    <input type="password" id="newPassword" placeholder="输入新密码">
                </div>
                <div class="password-input-group">
                    <label for="confirmPassword">确认新密码：</label>
                    <input type="password" id="confirmPassword" placeholder="再次输入新密码">
                </div>
                <button class="password-btn" id="savePasswordBtn">保存密码</button>
                <button class="password-btn cancel-btn" id="cancelChangePassword" style="background: #e0e0e0; color: #666;">取消</button>
                <div class="password-error" id="changePasswordError"></div>
            </div>
        </div>
    </div>
    
    <div class="container" id="appContainer" style="display: none;">
        <header>
            <div class="class-controls">
                <div class="class-title" id="classTitleBtn">
                    <span>三年(4)班积分系统</span>
                    <span class="emoji">📚✨</span>
                </div>
                <select id="viewMode" class="view-mode-select">
                    <option value="individual">个人积分</option>
                    <option value="group">小组积分</option>
                </select>
            </div>
            
            <div class="step-value">当前步值: <span id="currentStep">1</span></div>
            
            <div class="class-manager">
                <button class="class-btn" id="newClassBtn">
                    <i class="fas fa-plus-circle"></i> 创建新班级
                </button>
                <button class="class-btn" id="switchClassBtn">
                    <i class="fas fa-exchange-alt"></i> 切换班级
                </button>
                <button class="class-btn" id="changePasswordBtn">
                    <i class="fas fa-key"></i> 修改密码
                </button>
                <button class="class-btn" id="timerBtn">
                    <i class="fas fa-clock"></i> 倒计时
                </button>
            </div>
        </header>
        
        <div class="menu-bar">
            <button class="menu-btn individual-only" id="addAllBtn">
                <i class="fas fa-user-friends"></i> 全班加分
            </button>
            <button class="menu-btn individual-only" id="resetAllBtn">
                <i class="fas fa-redo"></i> 全班清零
            </button>
            <button class="menu-btn" id="rankingBtn">
                <i class="fas fa-trophy"></i> 排行榜
            </button>
            <button class="menu-btn random" id="randomPickBtn">
                <i class="fas fa-random"></i> 随机点名
            </button>
            <label class="file-input-label" for="fileInput">
                <i class="fas fa-file-import"></i> 导入积分
            </label>
            <input type="file" id="fileInput" accept=".xlsx, .xls">
            <button class="menu-btn" id="exportBtn">
                <i class="fas fa-file-export"></i> 导出积分
            </button>
            <button class="menu-btn" id="studentManagerBtn">
                <i class="fas fa-users"></i> 学生管理
            </button>
            <button class="menu-btn delete" id="deleteAllBtn">
                <i class="fas fa-trash-alt"></i> 删除所有学生
            </button>
            <button class="menu-btn step" id="changeStepBtn">
                <i class="fas fa-football"></i> 修改步值
            </button>
            <button class="menu-btn shop" id="shopBtn">
                <i class="fas fa-store"></i> 积分商城
            </button>
            <button class="menu-btn record" id="recordBtn">
                <i class="fas fa-history"></i> 兑换记录
            </button>
            <button class="menu-btn summary individual-only" id="summaryBtn">
                <i class="fas fa-calculator"></i> 积分汇总
            </button>
