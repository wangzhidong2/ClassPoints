        function showChangePasswordForm() {
            document.getElementById('passwordForm').style.display = 'none';
            document.getElementById('changePasswordForm').style.display = 'block';
        }
        
        function changePassword() {
            const oldPassword = document.getElementById('oldPassword').value;
            const newPassword = document.getElementById('newPassword').value;
            const confirmPassword = document.getElementById('confirmPassword').value;
            const savedPassword = localStorage.getItem('systemPassword') || '123456';
            
            if (oldPassword !== savedPassword) {
                document.getElementById('changePasswordError').textContent = '原密码错误';
                return;
            }
            
            if (newPassword.length < 6) {
                document.getElementById('changePasswordError').textContent = '密码长度至少6位';
                return;
            }
            
            if (newPassword !== confirmPassword) {
                document.getElementById('changePasswordError').textContent = '两次输入的新密码不一致';
                return;
            }
            
            localStorage.setItem('systemPassword', newPassword);
            scheduleAutoSaveToFile();
            showNotification('密码修改成功');
            document.getElementById('changePasswordForm').style.display = 'none';
            document.getElementById('passwordForm').style.display = 'block';
            document.getElementById('oldPassword').value = '';
            document.getElementById('newPassword').value = '';
            document.getElementById('confirmPassword').value = '';
            document.getElementById('changePasswordError').textContent = '';
        }
        
        // 随机点名功能
        function startRandomPick() {
            const students = classes[currentClass].students;
            if (!students || students.length === 0) {
                showNotification('班级中没有学生', true);
                return;
            }
            
            document.getElementById('startRandomBtn').style.display = 'none';
            document.getElementById('stopRandomBtn').style.display = 'block';
            
            const display = document.getElementById('randomStudentDisplay');
            display.classList.add('random-animation');
            
            randomPickInterval = setInterval(() => {
                const randomIndex = Math.floor(Math.random() * students.length);
                display.textContent = students[randomIndex].name;
                currentSelectedStudent = students[randomIndex].name;
            }, 100);
        }
        
        function stopRandomPick() {
            clearInterval(randomPickInterval);
            const display = document.getElementById('randomStudentDisplay');
            display.classList.remove('random-animation');
            
            document.getElementById('startRandomBtn').style.display = 'block';
            document.getElementById('stopRandomBtn').style.display = 'none';
            
            const students = classes[currentClass].students;
            const selectedStudent = students.find(s => s.name === currentSelectedStudent);
            
            if (!selectedStudent) return;
            
            // 添加到历史记录
            const timestamp = new Date().toLocaleTimeString();
            randomPickHistory.unshift({
                student: selectedStudent.name,
                group: selectedStudent.group,
                time: timestamp
            });
            
            // 更新历史显示
            updatePickHistory();
            
            showNotification(`已随机选择: ${selectedStudent.name} (${selectedStudent.group})`);
        }
        
        function updatePickHistory() {
            const historyContainer = document.getElementById('pickHistory');
            historyContainer.innerHTML = '';
            
            randomPickHistory.slice(0, 5).forEach(item => {
                const historyItem = document.createElement('div');
                historyItem.className = 'history-item';
                historyItem.innerHTML = `
                    <span>${item.student} (${item.group})</span> 
                    <span style="float: right;">${item.time}</span>
                `;
                historyContainer.appendChild(historyItem);
            });
        }
        
        // 为随机选择的学生加减分
        function adjustRandomPoints(change) {
            const pointsInput = document.getElementById('pointsInput');
            const points = parseInt(pointsInput.value) || 1;
            
            if (!currentSelectedStudent) {
                showNotification('请先选择一名学生', true);
                return;
            }
            
            const students = classes[currentClass].students;
            const student = students.find(s => s.name === currentSelectedStudent);
            
            if (!student) {
                showNotification('未找到该学生', true);
                return;
            }
            
            student.score += change * points;
            saveData();
            
            if (viewMode === 'individual') {
                renderStudents();
            } else {
                renderGroups();
            }
            
            showNotification(`已${change > 0 ? '增加' : '减少'} ${currentSelectedStudent} ${Math.abs(change * points)} 分`);
        }
        
        // 打开购物车
        function openCart(index) {
            const students = classes[currentClass].students;
            if (!students || index >= students.length) return;
            
            currentStudentCart = index;
            cart = []; // 清空购物车
            updateCart();
            
            // 显示购物车
            cartPopup.style.display = 'block';
        }
        
        // 更新购物车
        function updateCart() {
            cartBody.innerHTML = '';
            
            if (cart.length === 0) {
                cartBody.innerHTML = '<div style="text-align:center; padding:30px; color:#aaa;">购物车是空的</div>';
                cartTotalPoints.textContent = '0';
                return;
            }
            
            let totalPoints = 0;
            
            cart.forEach(item => {
                const product = products.find(p => p.id === item.productId);
                if (!product) return;
                
                totalPoints += product.points;
                
                const cartItem = document.createElement('div');
                cartItem.className = 'cart-item';
                cartItem.innerHTML = `
                    <div class="cart-item-image">
                        ${product.image ? `<img src="${product.image}" style="width:100%;height:100%;object-fit:cover;border-radius:8px;">` : '<i class="fas fa-box"></i>'}
                    </div>
                    <div class="cart-item-info">
                        <div class="cart-item-name">${product.name}</div>
                        <div class="cart-item-points">${product.points}积分</div>
                    </div>
                    <div class="cart-item-remove" data-id="${product.id}" style="color:#ff6b6b; cursor:pointer;">
                        <i class="fas fa-trash"></i>
                    </div>
                `;
                cartBody.appendChild(cartItem);
            });
            
            cartTotalPoints.textContent = totalPoints;
            
            // 添加删除事件
            document.querySelectorAll('.cart-item-remove').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    const productId = parseInt(e.currentTarget.dataset.id);
                    removeFromCart(productId);
                });
            });
        }
        
        // 从购物车移除商品
        function removeFromCart(productId) {
            cart = cart.filter(item => item.productId !== productId);
            updateCart();
        }
        
        // 兑换商品
        function checkoutCart() {
            const students = classes[currentClass].students;
            if (!students || currentStudentCart === null) return;
            
            const student = students[currentStudentCart];
            let totalPoints = 0;
            
            // 计算总积分
            cart.forEach(item => {
                const product = products.find(p => p.id === item.productId);
                if (product) {
                    totalPoints += product.points;
                }
            });
            
            // 检查积分是否足够
            if (student.score < totalPoints) {
                showNotification('积分不足，无法兑换', true);
                return;
            }
            
            // 扣除积分
            student.score -= totalPoints;
            
            // 更新商品库存并记录兑换历史
            cart.forEach(item => {
                const product = products.find(p => p.id === item.productId);
                if (product) {
                    product.stock--;
                    if (product.stock <= 0) {
                        product.status = "soldout";
                    }
                    
                    // 记录兑换历史
                    redeemHistory.push({
                        studentName: student.name,
                        className: currentClass,
                        productName: product.name,
                        points: product.points,
                        timestamp: new Date().toISOString()
                    });
                }
            });
            
            // 保存数据
            saveData();
            
            // 关闭购物车
            cartPopup.style.display = 'none';
            cart = [];
            
            if (viewMode === 'individual') {
                renderStudents();
            } else {
                renderGroups();
            }
            
            showNotification(`成功兑换商品，扣除${totalPoints}积分`);
        }
        
        // 渲染商品列表
        function renderProducts() {
            productGrid.innerHTML = '';
            
            if (products.length === 0) {
                productGrid.innerHTML = '<div class="empty-state">暂无商品</div>';
                return;
            }
            
            products.forEach(product => {
                const productCard = document.createElement('div');
                productCard.className = `product-card ${product.status === 'soldout' ? 'inactive-product' : ''}`;
                
                // 商品图片
                let imageHtml = '<i class="fas fa-box"></i>';
                if (product.image) {
                    imageHtml = `<img src="${product.image}" style="width:100%;height:100%;object-fit:cover;border-radius:10px;">`;
                }
                
                productCard.innerHTML = `
                    <div class="product-image" style="${product.image ? 'background:white;' : ''}">
                        ${imageHtml}
                    </div>
                    <div class="product-name">${product.name}</div>
                    <div class="product-points">${product.points}积分</div>
                    <div class="product-stock">库存: ${product.stock}</div>
                    <div class="product-status ${product.status === 'available' ? 'status-available' : 'status-soldout'}">
                        ${product.status === 'available' ? '上架中' : '已售罄'}
                    </div>
                    <button class="redeem-btn" data-id="${product.id}" ${product.stock <= 0 || product.status === 'soldout' ? 'disabled' : ''}>
                        <i class="fas fa-shopping-cart"></i> 加入购物车
                    </button>
                    <button class="delete-product-btn" data-id="${product.id}">
                        <i class="fas fa-trash"></i> 删除商品
                    </button>
                `;
                
                productGrid.appendChild(productCard);
                
                // 添加事件监听
                const redeemBtn = productCard.querySelector('.redeem-btn');
                if (redeemBtn) {
                    redeemBtn.addEventListener('click', () => {
                        cart.push({
                            productId: product.id,
                            timestamp: new Date().toISOString()
                        });
                        updateCart();
                        showNotification(`已将${product.name}加入购物车`);
                    });
                }
                
                // 添加删除按钮事件
                const deleteBtn = productCard.querySelector('.delete-product-btn');
                if (deleteBtn) {
                    deleteBtn.addEventListener('click', (e) => {
                        const productId = parseInt(e.currentTarget.dataset.id);
                        deleteProduct(productId);
                    });
                }
            });
        }
        
        // 删除商品
        function deleteProduct(productId) {
            if (confirm('确定要删除这个商品吗？')) {
                products = products.filter(p => p.id !== productId);
                saveData();
                renderProducts();
                showNotification('商品已删除');
            }
        }
        
        // 渲染兑换记录
        function renderRedeemHistory() {
            redeemHistoryBody.innerHTML = '';
            
            if (redeemHistory.length === 0) {
                redeemHistoryBody.innerHTML = '<tr><td colspan="5" style="text-align:center;padding:30px;color:#aaa;">暂无兑换记录</td></tr>';
                return;
            }
            
            // 生成月份和年份选项
            const monthFilter = document.getElementById('monthFilter');
            const yearFilter = document.getElementById('yearFilter');
            const classFilter = document.getElementById('classFilterRecord');
            
            // 清空选项（保留第一个选项）
            while (monthFilter.options.length > 1) monthFilter.remove(1);
            while (yearFilter.options.length > 1) yearFilter.remove(1);
            while (classFilter.options.length > 1) classFilter.remove(1);
            
            // 获取所有唯一的年份和月份
            const years = new Set();
            const months = new Set();
            const classesSet = new Set();
            
            redeemHistory.forEach(record => {
                const date = new Date(record.timestamp);
                years.add(date.getFullYear());
                months.add(date.getMonth() + 1);
                classesSet.add(record.className);
            });
            
            // 添加月份选项
            const monthNames = ["一月", "二月", "三月", "四月", "五月", "六月", 
                              "七月", "八月", "九月", "十月", "十一月", "十二月"];
            
            monthNames.forEach((name, index) => {
                if (months.has(index + 1)) {
                    const option = document.createElement('option');
                    option.value = index + 1;
                    option.textContent = name;
                    monthFilter.appendChild(option);
                }
            });
            
            // 添加年份选项
            Array.from(years).sort().forEach(year => {
                const option = document.createElement('option');
                option.value = year;
                option.textContent = year;
                yearFilter.appendChild(option);
            });
            
            // 添加班级选项
            Array.from(classesSet).forEach(className => {
                const option = document.createElement('option');
                option.value = className;
                option.textContent = className;
                classFilter.appendChild(option);
            });
            
            // 显示所有记录
            redeemHistory.forEach(record => {
                const date = new Date(record.timestamp);
                const dateStr = `${date.getFullYear()}-${(date.getMonth()+1).toString().padStart(2, '0')}-${date.getDate().toString().padStart(2, '0')} ${date.getHours().toString().padStart(2, '0')}:${date.getMinutes().toString().padStart(2, '0')}`;
                
                const row = document.createElement('tr');
                row.innerHTML = `
                    <td>${record.studentName}</td>
                    <td>${record.className}</td>
                    <td>${record.productName}</td>
                    <td>${record.points}</td>
                    <td>${dateStr}</td>
                `;
                redeemHistoryBody.appendChild(row);
            });
        }
        
        // 应用兑换记录筛选
        function applyRecordFilter() {
            const month = document.getElementById('monthFilter').value;
            const year = document.getElementById('yearFilter').value;
            const className = document.getElementById('classFilterRecord').value;
            
            const filteredHistory = redeemHistory.filter(record => {
                const date = new Date(record.timestamp);
                const recordYear = date.getFullYear();
                const recordMonth = date.getMonth() + 1;
                
                if (year !== 'all' && recordYear != year) return false;
                if (month !== 'all' && recordMonth != month) return false;
                if (className !== 'all' && record.className !== className) return false;
                
                return true;
            });
            
            // 更新显示
            redeemHistoryBody.innerHTML = '';
            
            if (filteredHistory.length === 0) {
                redeemHistoryBody.innerHTML = '<tr><td colspan="5" style="text-align:center;padding:30px;color:#aaa;">无匹配的兑换记录</td></tr>';
                return;
            }
            
            filteredHistory.forEach(record => {
                const date = new Date(record.timestamp);
                const dateStr = `${date.getFullYear()}-${(date.getMonth()+1).toString().padStart(2, '0')}-${date.getDate().toString().padStart(2, '0')} ${date.getHours().toString().padStart(2, '0')}:${date.getMinutes().toString().padStart(2, '0')}`;
                
                const row = document.createElement('tr');
                row.innerHTML = `
                    <td>${record.studentName}</td>
                    <td>${record.className}</td>
                    <td>${record.productName}</td>
                    <td>${record.points}</td>
                    <td>${dateStr}</td>
