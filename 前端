                </div>
                <input type="text" id="newReasonInput" placeholder="输入新原因...">
                <button class="history-btn" id="saveReasonBtn" style="margin-top: 10px;">保存为新标签</button>
            </div>
            <div class="action-btns-modal">
                <button class="confirm-btn" id="confirmAddScore">确定</button>
                <button class="cancel-btn" id="cancelAddScore">取消</button>
            </div>
        </div>
    </div>
    
    <!-- 学生管理模态框 -->
