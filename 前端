        // ============ JSON 文件持久化 ============
        let boundFileHandle = null;      // 绑定的文件句柄（File System Access API）
        let autoSaveTimer = null;        // 防抖定时器
        let isAutoSaving = false;        // 是否正在写入文件
        const FILE_HANDLE_DB = 'ClassPointsDB';
        const FILE_HANDLE_STORE = 'fileHandles';
        const FILE_HANDLE_KEY = 'boundDataFile';

        // 收集所有需要持久化的数据
        function getAllDataObject() {
            return {
                version: 1,
                exportTime: new Date().toISOString(),
                classes: classes,
                products: products,
                redeemHistory: redeemHistory,
                currentClass: currentClass,
                stepValue: stepValue,
                viewMode: viewMode,
                reasonTags: reasonTags,
                systemPassword: localStorage.getItem('systemPassword') || '123456'
            };
        }

        // 将数据对象应用到内存变量
        function applyDataObject(data) {
            if (!data || typeof data !== 'object') throw new Error('数据格式不正确');
            if (data.classes) classes = data.classes;
            if (data.products) products = data.products;
            if (data.redeemHistory) redeemHistory = data.redeemHistory;
            if (data.currentClass) currentClass = data.currentClass;
            if (typeof data.stepValue === 'number') stepValue = data.stepValue;
            if (data.viewMode) viewMode = data.viewMode;
            if (data.reasonTags) reasonTags = data.reasonTags;
            if (data.systemPassword) localStorage.setItem('systemPassword', data.systemPassword);
            // 同步到 localStorage 缓存
            localStorage.setItem('classPointsSystem', JSON.stringify(classes));
            localStorage.setItem('classProducts', JSON.stringify(products));
            localStorage.setItem('redeemHistory', JSON.stringify(redeemHistory));
            localStorage.setItem('currentClass', currentClass);
            localStorage.setItem('stepValue', stepValue);
            localStorage.setItem('viewMode', viewMode);
            localStorage.setItem('reasonTags', JSON.stringify(reasonTags));
        }

        // 导出全部数据为 JSON 文件（下载）
        function exportAllDataToJSON() {
            try {
                const data = getAllDataObject();
                const jsonStr = JSON.stringify(data, null, 2);
                const blob = new Blob([jsonStr], { type: 'application/json' });
                const url = URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                const dateStr = new Date().toISOString().slice(0, 10);
                a.download = `课堂积分数据备份_${dateStr}.json`;
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
                URL.revokeObjectURL(url);
                showNotification('数据已导出为 JSON 文件');
            } catch (err) {
                console.error(err);
                showNotification('导出失败：' + err.message, true);
            }
        }

        // 从 JSON 文件恢复全部数据
        function importAllDataFromJSON(file) {
            const reader = new FileReader();
            reader.onload = function(e) {
                try {
                    const data = JSON.parse(e.target.result);
                    // 取消可能挂起的自动保存，避免用旧缓存覆盖刚恢复的数据
                    if (autoSaveTimer) { clearTimeout(autoSaveTimer); autoSaveTimer = null; }
                    applyDataObject(data);
                    updateClassTitle();
                    updateStepValue();
                    if (viewModeSelect) viewModeSelect.value = viewMode;
                    updateViewMode();
                    showNotification('数据已从 JSON 文件恢复');
                } catch (err) {
                    console.error(err);
                    showNotification('恢复失败：' + err.message, true);
                }
            };
            reader.onerror = function() {
                showNotification('读取文件失败', true);
            };
            reader.readAsText(file);
        }

        // ============ IndexedDB 文件句柄存储 ============
        function openHandleDB() {
            return new Promise((resolve, reject) => {
                const req = indexedDB.open(FILE_HANDLE_DB, 1);
                req.onupgradeneeded = function() {
                    req.result.createObjectStore(FILE_HANDLE_STORE);
                };
                req.onsuccess = () => resolve(req.result);
                req.onerror = () => reject(req.error);
            });
        }

        async function saveHandleToDB(handle) {
            const db = await openHandleDB();
            return new Promise((resolve, reject) => {
                const tx = db.transaction(FILE_HANDLE_STORE, 'readwrite');
                tx.objectStore(FILE_HANDLE_STORE).put(handle, FILE_HANDLE_KEY);
                tx.oncomplete = () => resolve();
                tx.onerror = () => reject(tx.error);
            });
        }

        async function getHandleFromDB() {
            const db = await openHandleDB();
            return new Promise((resolve, reject) => {
                const tx = db.transaction(FILE_HANDLE_STORE, 'readonly');
                const req = tx.objectStore(FILE_HANDLE_STORE).get(FILE_HANDLE_KEY);
                req.onsuccess = () => resolve(req.result || null);
                req.onerror = () => reject(req.error);
            });
        }

        async function removeHandleFromDB() {
            const db = await openHandleDB();
            return new Promise((resolve, reject) => {
                const tx = db.transaction(FILE_HANDLE_STORE, 'readwrite');
                tx.objectStore(FILE_HANDLE_STORE).delete(FILE_HANDLE_KEY);
                tx.oncomplete = () => resolve();
                tx.onerror = () => reject(tx.error);
            });
        }

        // 校验文件句柄权限
        async function verifyPermission(handle, readWrite) {
            if (!handle) return false;
            const opts = { mode: readWrite ? 'readwrite' : 'read' };
            if ((await handle.queryPermission(opts)) === 'granted') return true;
            if ((await handle.requestPermission(opts)) === 'granted') return true;
            return false;
        }

        // ============ 绑定 / 解绑数据文件 ============
        async function bindDataFile() {
            if (!window.showSaveFilePicker) {
                showNotification('当前浏览器不支持自动保存，请使用手动导出/恢复', true);
                return;
            }
            try {
                const handle = await window.showSaveFilePicker({
                    suggestedName: '课堂积分数据.json',
                    types: [{
                        description: 'JSON 数据文件',
                        accept: { 'application/json': ['.json'] }
                    }]
                });
                const ok = await verifyPermission(handle, true);
                if (!ok) {
                    showNotification('未获得文件写入权限', true);
                    return;
                }
                boundFileHandle = handle;
                await saveHandleToDB(handle);
                // 绑定后立即写入一次当前数据
                await saveToBoundFile(true);
                updateDataManageUI();
                showNotification('已绑定数据文件，将自动保存');
            } catch (err) {
                if (err.name !== 'AbortError') {
                    console.error(err);
                    showNotification('绑定失败：' + err.message, true);
                }
            }
        }

        async function unbindDataFile() {
            boundFileHandle = null;
            await removeHandleFromDB();
            updateDataManageUI();
            showNotification('已解除数据文件绑定');
        }

        // 保存到已绑定的文件
        async function saveToBoundFile(silent) {
            if (!boundFileHandle) {
                if (!silent) showNotification('未绑定数据文件', true);
                return false;
            }
            try {
                const ok = await verifyPermission(boundFileHandle, true);
                if (!ok) {
                    if (!silent) showNotification('未获得文件写入权限', true);
                    return false;
                }
                const data = getAllDataObject();
                const jsonStr = JSON.stringify(data, null, 2);
                const writable = await boundFileHandle.createWritable();
                await writable.write(jsonStr);
                await writable.close();
                if (!silent) showNotification('数据已保存到文件');
                return true;
            } catch (err) {
                console.error(err);
                if (!silent) showNotification('保存到文件失败：' + err.message, true);
                return false;
            }
        }

        // 从已绑定的文件载入
        async function loadFromBoundFile() {
            if (!boundFileHandle) {
                showNotification('未绑定数据文件', true);
                return false;
            }
            try {
                const ok = await verifyPermission(boundFileHandle, false);
                if (!ok) {
                    showNotification('未获得文件读取权限', true);
                    return false;
                }
                // 取消可能挂起的自动保存，避免用旧缓存覆盖刚载入的文件数据
                if (autoSaveTimer) { clearTimeout(autoSaveTimer); autoSaveTimer = null; }
                const file = await boundFileHandle.getFile();
                const text = await file.text();
                const data = JSON.parse(text);
                applyDataObject(data);
                updateClassTitle();
                updateStepValue();
                if (viewModeSelect) viewModeSelect.value = viewMode;
                updateViewMode();
                showNotification('已从文件载入数据');
                return true;
            } catch (err) {
                console.error(err);
                showNotification('从文件载入失败：' + err.message, true);
                return false;
            }
        }

        // 防抖自动保存
        function scheduleAutoSaveToFile() {
            if (!boundFileHandle) return;
            if (autoSaveTimer) clearTimeout(autoSaveTimer);
            autoSaveTimer = setTimeout(async () => {
                if (isAutoSaving) return;
                isAutoSaving = true;
                try {
                    await saveToBoundFile(true);
                } finally {
                    isAutoSaving = false;
                }
            }, 800);
        }

        // 启动时尝试恢复文件绑定，并从文件载入数据
        async function initDataFileBinding() {
            try {
                const handle = await getHandleFromDB();
                if (!handle) return;
                // 静默查询权限，若已授权则自动载入
                const perm = await handle.queryPermission({ mode: 'read' });
                if (perm === 'granted') {
                    boundFileHandle = handle;
                    await loadFromBoundFile();
                    updateDataManageUI();
                } else {
                    // 权限未授予，保留句柄等待用户在数据管理中确认
                    boundFileHandle = handle;
                    updateDataManageUI();
                }
            } catch (err) {
                console.error('初始化文件绑定失败', err);
            }
        }

