        // 设置拖拽功能
        function setupDragAndDrop() {
            const studentItems = document.querySelectorAll('.group-student-item');
            
            studentItems.forEach(item => {
                item.addEventListener('dragstart', handleDragStart);
                item.addEventListener('dragover', handleDragOver);
                item.addEventListener('dragenter', handleDragEnter);
                item.addEventListener('dragleave', handleDragLeave);
                item.addEventListener('drop', handleDrop);
                item.addEventListener('dragend', handleDragEnd);
            });
        }
        
        // 拖拽开始
        function handleDragStart(e) {
            draggingStudent = this;
            dragSourceGroup = this.dataset.group;
            this.classList.add('dragging');
            e.dataTransfer.effectAllowed = 'move';
            e.dataTransfer.setData('text/plain', this.dataset.name);
        }
        
        // 拖拽经过
        function handleDragOver(e) {
            e.preventDefault();
            e.dataTransfer.dropEffect = 'move';
        }
        
        // 拖拽进入
        function handleDragEnter(e) {
            this.classList.add('drag-over');
        }
        
        // 拖拽离开
        function handleDragLeave(e) {
            this.classList.remove('drag-over');
        }
        
        // 放置
        function handleDrop(e) {
            e.preventDefault();
            this.classList.remove('drag-over');
            
            const studentName = e.dataTransfer.getData('text/plain');
            const targetGroup = this.closest('.group-student-list').id.replace('group-', '');
            
            if (dragSourceGroup !== targetGroup) {
                // 移动到不同小组
                moveStudentToGroup(studentName, targetGroup);
            } else {
                // 在同一小组内调整位置
                const sourceIndex = Array.from(this.parentNode.children).indexOf(draggingStudent);
                const targetIndex = Array.from(this.parentNode.children).indexOf(this);
                
                if (sourceIndex !== targetIndex) {
                    const classData = classes[currentClass];
                    const students = classData.students;
                    
                    // 找到学生在数组中的位置
                    const studentIndex = students.findIndex(s => s.name === studentName);
                    if (studentIndex !== -1) {
                        // 更新小组内学生的顺序
                        const groupStudents = students.filter(s => s.group === targetGroup);
                        
                        // 交换位置
                        const sourceStudent = groupStudents[sourceIndex];
                        const targetStudent = groupStudents[targetIndex];
                        
                        // 交换学生在数组中的位置
                        const sourceGlobalIndex = students.findIndex(s => s.name === sourceStudent.name);
                        const targetGlobalIndex = students.findIndex(s => s.name === targetStudent.name);
                        
                        [students[sourceGlobalIndex], students[targetGlobalIndex]] = [students[targetGlobalIndex], students[sourceGlobalIndex]];
                        
                        saveData();
                        renderGroups();
                        showNotification(`已调整 ${studentName} 的位置`);
                    }
                }
            }
        }
        
