        // 渲染积分汇总
        function renderSummary() {
            summaryTableBody.innerHTML = '';
            
            const classFilter = document.getElementById('classFilter').value;
            const searchQuery = document.getElementById('studentSearch').value.toLowerCase().trim();
            
            const allClasses = Object.keys(classes);
            const studentSummary = {};
            
            // 收集所有学生积分
            allClasses.forEach(className => {
                // 应用班级筛选
                if (classFilter !== 'all' && className !== classFilter) return;
                
                if (classes[className].students) {
                    classes[className].students.forEach(student => {
                        if (!studentSummary[student.name]) {
                            studentSummary[student.name] = {
                                total: 0,
                                classes: [],
                                details: {}
                            };
                        }
                        
                        studentSummary[student.name].total += student.score;
                        studentSummary[student.name].classes.push(className);
                        studentSummary[student.name].details[className] = student.score;
                    });
                }
            });
            
            // 转换为数组并排序
            let summaryArray = Object.keys(studentSummary).map(name => ({
                name,
                total: studentSummary[name].total,
                classCount: studentSummary[name].classes.length,
                details: studentSummary[name].details
            })).sort((a, b) => b.total - a.total);
            
            // 应用学生搜索
            if (searchQuery) {
                summaryArray = summaryArray.filter(item => 
                    item.name.toLowerCase().includes(searchQuery)
                );
            }
            
            // 渲染表格
            summaryArray.forEach(item => {
                const row = document.createElement('tr');
                
                // 创建明细字符串
                let details = '';
                Object.keys(item.details).forEach(className => {
                    details += `${className}: ${item.details[className]}分<br>`;
                });
                
                row.innerHTML = `
                    <td>${item.name}</td>
                    <td>${item.total}</td>
                    <td>${item.classCount}</td>
                    <td>${details}</td>
                `;
                summaryTableBody.appendChild(row);
            });
        }
        
