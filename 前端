                        </span>
                    </div>
                `;
                
                const deleteBtn = listItem.querySelector('.student-list-delete');
                deleteBtn.addEventListener('click', () => {
                    // 找到该学生在全局列表中的索引
                    const globalIndex = classes[className].students.findIndex(s => s.name === student.name);
                    if (globalIndex !== -1) {
                        classes[className].students.splice(globalIndex, 1);
                        
                        // 更新组长状态
                        updateGroupLeaders();
                        
                        saveData();
                        updateStudentList();
                        
